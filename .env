# ============================================================================
# EventMate - Centralized Environment Configuration
# ============================================================================
# This file contains all environment variables for the EventMate microservices
# architecture. Configure these values and they will be used across all services.
# ============================================================================

# ============================================================================
# COMMON/SHARED VARIABLES
# ============================================================================

# Database Credentials (shared across most services)
DB_PASSWORD=ayush@postgres

# JWT Token Configuration
JWT_SECRET=wxwflkjjQDfgerERTfweFWERWerferwFWER

# Internal Service Communication Token
INTERNAL_TOKEN=AWFAWvsdcascawEFAWEEFDASDwadwdsafaewrrfewf

# Eureka Server Configuration
EUREKA_SERVER_URL=http://localhost:8761/eureka
EUREKA_REGISTER_WITH_EUREKA=true
EUREKA_FETCH_REGISTRY=true
EUREKA_PREFER_IP_ADDRESS=true

# ============================================================================
# SERVICE: EUREKA SERVER (Port: 8761)
# ============================================================================
EUREKA_SERVER_PORT=8761
EUREKA_SERVER_REGISTER_WITH_EUREKA=false
EUREKA_SERVER_FETCH_REGISTRY=false

# ============================================================================
# SERVICE: GATEWAY (Port: 8080)
# ============================================================================
GATEWAY_PORT=8080
GATEWAY_SECURITY_ENABLED=true

# ============================================================================
# SERVICE: AUTH (Port: 8081)
# ============================================================================
AUTH_SERVICE_PORT=8081
AUTH_DB_URL=jdbc:postgresql://localhost:5432/eventmate-auth
AUTH_DB_USERNAME=postgres
AUTH_JPA_DDL_AUTO=update
AUTH_JPA_SHOW_SQL=true

# JWT Configuration for Auth Service
AUTH_JWT_EXPIRATION_MS=86400000
AUTH_JWT_REFRESH_TOKEN_EXPIRATION_MS=86400000

# Auth Service Security
AUTH_SECURITY_ENABLED=true

# ============================================================================
# SERVICE: TENANT (Port: 8082)
# ============================================================================
TENANT_SERVICE_PORT=8082
TENANT_DB_URL=jdbc:postgresql://localhost:5432/eventmate-auth
TENANT_DB_USERNAME=postgres
TENANT_JPA_DDL_AUTO=update
TENANT_JPA_SHOW_SQL=true

# Tenant Service Security
TENANT_SECURITY_ENABLED=true

# ============================================================================
# SERVICE: EVENT (Port: 8083)
# ============================================================================
EVENT_SERVICE_PORT=8083
EVENT_DB_URL=jdbc:postgresql://localhost:5432/eventmate-event
EVENT_DB_USERNAME=postgres
EVENT_JPA_DDL_AUTO=update
EVENT_JPA_SHOW_SQL=true

# Redis Configuration for Event Service
EVENT_REDIS_HOST=redis-13318.crce292.ap-south-1-2.ec2.cloud.redislabs.com
EVENT_REDIS_PORT=13318
EVENT_REDIS_USERNAME=default
EVENT_REDIS_PASSWORD=NaBMEB7228jJKJgkbjIhZ6K6mywF0zCW

# Kafka Configuration for Event Service
EVENT_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
EVENT_KAFKA_CONSUMER_GROUP_ID=event-service
EVENT_KAFKA_CONSUMER_AUTO_OFFSET_RESET=earliest

# Event Service Security
EVENT_SECURITY_ENABLED=true

# ============================================================================
# SERVICE: BOOKING (Port: 8084)
# ============================================================================
BOOKING_SERVICE_PORT=8084
BOOKING_DB_URL=jdbc:postgresql://localhost:5432/eventmate-bookings
BOOKING_DB_USERNAME=postgres
BOOKING_JPA_DDL_AUTO=update
BOOKING_JPA_SHOW_SQL=true

# Redis Configuration for Booking Service
BOOKING_REDIS_HOST=redis-13318.crce292.ap-south-1-2.ec2.cloud.redislabs.com
BOOKING_REDIS_PORT=13318
BOOKING_REDIS_USERNAME=default
BOOKING_REDIS_PASSWORD=NaBMEB7228jJKJgkbjIhZ6K6mywF0zCW

# Kafka Configuration for Booking Service
BOOKING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
BOOKING_KAFKA_CONSUMER_GROUP_ID=booking-service
BOOKING_KAFKA_CONSUMER_AUTO_OFFSET_RESET=earliest

# Booking Service Security
BOOKING_SECURITY_ENABLED=true

# ============================================================================
# SERVICE: PAYMENT (Port: 8085)
# ============================================================================
PAYMENT_SERVICE_PORT=8085
PAYMENT_DB_URL=jdbc:postgresql://localhost:5432/eventmate-payment
PAYMENT_DB_USERNAME=postgres
PAYMENT_JPA_DDL_AUTO=update
PAYMENT_JPA_SHOW_SQL=true

# Kafka Configuration for Payment Service
PAYMENT_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Payment Service Security
PAYMENT_SECURITY_ENABLED=true

# ============================================================================
# SERVICE: NOTIFICATION (Port: 8086)
# ============================================================================
NOTIFICATION_SERVICE_PORT=8086
NOTIFICATION_DB_URL=jdbc:postgresql://localhost:5432/eventmate-notification
NOTIFICATION_DB_USERNAME=postgres
NOTIFICATION_JPA_DDL_AUTO=update
NOTIFICATION_JPA_SHOW_SQL=true

# Kafka Configuration for Notification Service
NOTIFICATION_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
NOTIFICATION_KAFKA_CONSUMER_GROUP_ID=event-service
NOTIFICATION_KAFKA_CONSUMER_AUTO_OFFSET_RESET=earliest

# Email/SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=ayushpurohit141@gmail.com
SMTP_PASSWORD=nomlwetxufhmrupe
SMTP_AUTH=true
SMTP_STARTTLS_ENABLE=true

# Notification Service Security
NOTIFICATION_SECURITY_ENABLED=true

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL Host
DB_HOST=localhost
DB_PORT=5432
DB_DRIVER=org.postgresql.Driver

# ============================================================================
# KAFKA CONFIGURATION
# ============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Kafka Producer Settings (used by Payment and Booking services)
KAFKA_PRODUCER_KEY_SERIALIZER=org.apache.kafka.common.serialization.StringSerializer
KAFKA_PRODUCER_VALUE_SERIALIZER=org.springframework.kafka.support.serializer.JsonSerializer

# Kafka Consumer Settings
KAFKA_CONSUMER_KEY_DESERIALIZER=org.apache.kafka.common.serialization.StringDeserializer
KAFKA_CONSUMER_VALUE_DESERIALIZER=org.springframework.kafka.support.serializer.JsonDeserializer
KAFKA_CONSUMER_JSON_TRUSTED_PACKAGES=*
KAFKA_CONSUMER_JSON_USE_TYPE_HEADERS=false

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Shared Redis credentials for caching (used by Event and Booking services)
REDIS_HOST=redis-13318.crce292.ap-south-1-2.ec2.cloud.redislabs.com
REDIS_PORT=13318
REDIS_USERNAME=default
REDIS_PASSWORD=NaBMEB7228jJKJgkbjIhZ6K6mywF0zCW

# ============================================================================
# JPA/HIBERNATE CONFIGURATION (Optional)
# ============================================================================
JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect

# ============================================================================
# APPLICATION PROFILES
# ============================================================================
# Set the active profile: dev, prod, test
SPRING_PROFILES_ACTIVE=

